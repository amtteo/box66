# ─────────────── Supabase ───────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Publishable key (safe for the browser). Dashboard -> Project Settings -> API keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
# Secret key (SERVER ONLY — never expose to the browser)
SUPABASE_SECRET_KEY="sb_secret_xxx"

# ─────────────── Prisma / Postgres ───────────────
# Get both strings from Supabase Dashboard -> Connect.
# DATABASE_URL  = Session pooler (5432) — default for Next.js dev / long-running server.
#                 Use transaction pooler (6543 + ?pgbouncer=true) if 5432 is blocked.
# DIRECT_URL    = Session pooler (5432) for Prisma CLI — db.* direct host needs IPv6.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-DB-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-DB-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─────────────── Stripe (Kolo 6) ───────────────
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ─────────────── App ───────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
